# Nginx configuration for Shadow Azeroth
# Place this in /etc/nginx/sites-available/shadowazeroth and symlink to sites-enabled

server {
    listen 80;
    server_name 51.81.202.167;  # Replace with your domain if you have one

    # Proxy for the Next.js web app
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Proxy for SOAP (if you want to proxy it too, but better to keep separate port)
    # Uncomment if you want SOAP on /soap path
    # location /soap {
    #     proxy_pass http://localhost:7878;
    #     proxy_http_version 1.1;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }
}

