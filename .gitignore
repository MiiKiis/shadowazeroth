# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local VS Code deployment config (contains credentials)
.vscode/sftp.json

# --- Shadow Azeroth Custom Ignores ---
data/account-avatars.json
data/addons.json
package-lock.json

# --- SEGURIDAD Y LIMPIEZA ---
/*.js
/*.ts
!/src/**/*
!/next.config.ts
!/next-env.d.ts
!/eslint.config.mjs
/*.txt
/*.log
/*.sql
!/src/**/*.sql
/scratch/
/scripts/
/store shadow/